---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = "Контакти — виготовлення електрощитів | elektromontazh.kiev.ua";
const description = "Зв'яжіться з виробником електрощитів у Києві. Телефон, email, Viber, Telegram, WhatsApp. Відповідаємо протягом 1–2 робочих днів. Адреса: вул. Печенізька, 35/43.";
---
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href="https://elektromontazh.kiev.ua/kontakty" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/em-kontakty.css" />
</head>
<body>

<Header activePage="kontakty" />

<Breadcrumbs current="Контакти" parentLabel="Головна" parentHref="/" />

<!-- HERO -->
<div class="em-hero">
  <div class="em-hero-inner">
    <h1>Контакти</h1>
    <p class="em-hero-sub">Зв'яжіться зручним способом — відповідаємо протягом 1–2 робочих днів</p>
  </div>
</div>

<!-- КОНТАКТНИЙ БЛОК -->
<div class="em-section-alt" id="kontakty-blok">
  <div class="em-section-alt-inner">

    <span class="em-section-label">Зв'яжіться з нами</span>
    <h2>Як з нами зв'язатися</h2>

    <!-- Великий телефон -->
    <a href="tel:+380675097094" class="em-kontakty-phone">
      <svg class="em-kontakty-phone-icon" viewBox="0 0 24 24">
        <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z"/>
      </svg>
      +38 (067) 509-70-94
    </a>

    <!-- Реквізити + графік -->
    <div class="em-kontakty-info-grid">

      <div class="em-kontakty-info-card">
        <div class="em-kontakty-info-label">Email</div>
        <a href="mailto:5033455@gmail.com" class="em-kontakty-info-value">5033455@gmail.com</a>
      </div>

      <div class="em-kontakty-info-card">
        <div class="em-kontakty-info-label">Адреса</div>
        <span class="em-kontakty-info-value">Київ, вул. Печенізька, 35/43, оф. 168</span>
      </div>

      <div class="em-kontakty-info-card">
        <div class="em-kontakty-info-label">Месенджери</div>
        <span class="em-kontakty-info-value">Viber · Telegram · WhatsApp — за тим самим номером</span>
      </div>

    </div>

    <!-- Кнопки зв'язку -->
    <div class="em-contact-grid">
      <a href="tel:+380675097094" class="em-contact-card">
        <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z"/></svg>
        <span class="em-contact-card-label">Телефонувати</span>
      </a>
      <a href="mailto:5033455@gmail.com" class="em-contact-card">
        <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M2 4h20v16H2V4zm2 2v.01L12 13l8-6.99V6H4zm16 2.24l-7.39 6.47a1 1 0 0 1-1.22 0L4 8.24V18h16V8.24z"/></svg>
        <span class="em-contact-card-label">Написати email</span>
      </a>
      <a href="viber://chat?number=%2B380675097094" class="em-contact-card em-contact-card-viber">
        <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M12 2C6.5 2 2.4 5.6 2.4 10.4c0 2.6 1.3 4.9 3.4 6.5l-.5 3.7a.6.6 0 0 0 .9.6l3.6-2.1c.7.1 1.4.2 2.2.2 5.5 0 9.6-3.6 9.6-8.4S17.5 2 12 2z"/></svg>
        <span class="em-contact-card-label">Viber</span>
      </a>
      <a href="https://t.me/+380675097094" class="em-contact-card em-contact-card-telegram">
        <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M21.5 4.5L2.7 12c-.8.3-.8 1.5.1 1.7l4.6 1.4 1.8 5.5c.3.8 1.3.9 1.8.2l2.6-3.3 4.9 3.6c.7.5 1.7.1 1.9-.7l3-15c.2-.9-.7-1.7-1.6-1.4z"/></svg>
        <span class="em-contact-card-label">Telegram</span>
      </a>
      <a href="https://wa.me/380675097094" class="em-contact-card em-contact-card-whatsapp">
        <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 0-8.6 15L2 22l5.2-1.4A10 10 0 1 0 12 2zm5.6 14.3c-.2.7-1.4 1.3-1.9 1.4-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.7.8 1.8.1.2.1.3 0 .5-.1.2-.2.3-.3.5l-.5.5c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.5 1.5.3.1.5.1.6-.1l.7-.8c.2-.3.4-.2.7-.1l1.6.8c.2.1.4.2.4.4.1.2.1.7-.1 1.1z"/></svg>
        <span class="em-contact-card-label">WhatsApp</span>
      </a>
      <a href="https://www.google.com/maps/search/?api=1&query=Київ,+вул.+Печенізька,+35/43" target="_blank" rel="noopener" class="em-contact-card">
        <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
        <span class="em-contact-card-label">Відкрити на карті</span>
      </a>
    </div>

    <!-- Графік роботи -->
    <div class="em-kontakty-schedule">
      <div class="em-kontakty-schedule-title">Графік роботи</div>
      <div class="em-kontakty-schedule-grid">
        <div class="em-schedule-row em-schedule-row--work">
          <span class="em-schedule-day">Понеділок</span>
          <span class="em-schedule-time">9:00 – 17:00</span>
        </div>
        <div class="em-schedule-row em-schedule-row--off">
          <span class="em-schedule-day">Вівторок</span>
          <span class="em-schedule-time em-schedule-off">вихідний</span>
        </div>
        <div class="em-schedule-row em-schedule-row--work">
          <span class="em-schedule-day">Середа</span>
          <span class="em-schedule-time">9:00 – 17:00</span>
        </div>
        <div class="em-schedule-row em-schedule-row--work">
          <span class="em-schedule-day">Четвер</span>
          <span class="em-schedule-time">9:00 – 17:00</span>
        </div>
        <div class="em-schedule-row em-schedule-row--work">
          <span class="em-schedule-day">П'ятниця</span>
          <span class="em-schedule-time">9:00 – 17:00</span>
        </div>
        <div class="em-schedule-row em-schedule-row--off">
          <span class="em-schedule-day">Субота</span>
          <span class="em-schedule-time em-schedule-off">вихідний</span>
        </div>
        <div class="em-schedule-row em-schedule-row--off">
          <span class="em-schedule-day">Неділя</span>
          <span class="em-schedule-time em-schedule-off">вихідний</span>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- КАРТА -->
<section class="em-section">
  <span class="em-section-label">Адреса</span>
  <h2>Як нас знайти</h2>
  <p class="em-lead">Київ, вул. Печенізька, 35/43, оф. 168 — виробниче та офісне приміщення</p>

  <div class="em-kontakty-map-wrap">
    <iframe
      src="https://maps.google.com/maps?q=Київ,+вул.+Печенізька,+35%2F43&output=embed&z=16"
      width="100%"
      height="420"
      style="border:0; border-radius: 12px; display: block;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Розташування на карті — Київ, вул. Печенізька, 35/43"
    ></iframe>
  </div>

  <div class="em-kontakty-map-cta">
    <a
      href="https://www.google.com/maps/search/?api=1&query=Київ,+вул.+Печенізька,+35/43"
      target="_blank"
      rel="noopener"
      class="em-btn-primary"
    >
      Відкрити в Google Maps →
    </a>
  </div>
</section>

<Footer />

<script is:inline src="/js/em-site.js"></script>
</body>
</html>
